{
    "name": "Feishin",
    "slug": "feishin",
    "categories": [
        13
    ],
    "date_created": "2026-06-12",
    "type": "ct",
    "updateable": true,
    "privileged": false,
    "has_arm": false,
    "interface_port": 9180,
    "documentation": "https://github.com/jeffvli/feishin",
    "website": "https://feishin.vercel.app",
    "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons@main/webp/feishin.webp",
    "config_path": "/opt/feishin/.env",
    "description": "Modern self-hosted music player web client for Navidrome, Jellyfin, and OpenSubsonic-compatible servers.",
    "install_methods": [
        {
            "type": "default",
            "script": "ct/feishin.sh",
            "config_path": "/opt/feishin/.env",
            "resources": {
                "cpu": 2,
                "ram": 4096,
                "hdd": 8,
                "os": "Debian",
                "version": "13"
            }
        }
    ],
    "default_credentials": {
        "username": null,
        "password": null
    },
    "notes": [
        {
            "text": "Feishin is a client only. Configure your music backend URL (SERVER_URL) in /opt/feishin/.env, then restart nginx.",
            "type": "info"
        },
        {
            "text": "Default web URL is http://YOUR_IP:9180.",
            "type": "info"
        },
        {
            "text": "If you need a subpath deployment, set PUBLIC_PATH in /opt/feishin/.env and restart nginx.",
            "type": "info"
        }
    ]
}